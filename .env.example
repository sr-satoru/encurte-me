
# --- Url servidor ---
FRONTEND_URL=http://localhost:5173

# --- Banco de Dados ---
DATABASE_URL="file:./dev.db"

# --- Autenticação ---
JWT_SECRET="super-secret-key-change-me-in-production"
ALGORITHM="HS256"
COOKIE_NAME="auth_token"

# --- Redis ---
REDIS_URL="redis://localhost:6380/0"

# --- Encurtador de URLs ---
HASHID_SALT="sua-chave-secreta-mude-em-producao-2024"
HASHID_MIN_LENGTH=4
SCATTER_SECRET="scatter-chave-secreta-mude-em-producao-2024"
URL_ID_START=15000000

# --- Captcha (Cloudflare Turnstile tem prioridade sobre Google reCAPTCHA) ---
# RECAPTCHA_SECRET_KEY=sua_secret_key_do_google
# TURNSTILE_SECRET_KEY=

# --- Chaptcha do google ---
# VITE_RECAPTCHA_SITE_KEY=sua_site_key_do_google
# VITE_TURNSTILE_SITE_KEY=


# --- Email (SMTP para recuperação de senha) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
